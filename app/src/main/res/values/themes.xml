<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Launch theme: solid night ground, NO icon. The system reserves the
      animated-icon slot but our drawable is transparent, so nothing draws.
      After Activity creates, we hand off to Theme.Zad and our Compose
      SplashScreen draws the pouch live. No icon flash.
    -->
    <style name="Theme.Zad.Launch" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/night</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_blank</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/night</item>
        <item name="postSplashScreenTheme">@style/Theme.Zad</item>
    </style>

    <style name="Theme.Zad" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
